# Revolut People API (server only — never prefix with VITE_)
REVOLUT_EMAIL=your-email@company.com
REVOLUT_TOKEN=your-api-token

# Local API server
API_PORT=3001
PORT=3001
# Cache Revolut responses in memory (milliseconds)
API_CACHE_MS=3600000
STALE_REFRESH_MS=21600000
REVOLUT_PAGE_DELAY_MS=350
INCLUDE_SCORECARDS=true
INCLUDE_ALL_SCORECARDS=true

# Public site URL (optional in production — server uses request Host if unset)
# Local dev:
APP_URL=http://localhost:5173
# Production Render: https://next-performance.onrender.com
# Production Vercel UI: https://next-performance-beta.vercel.app

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-me-to-a-long-random-string
ALLOWED_EMAIL_DOMAIN=yourcompany.com
# Comma-separated emails that become admin on first Google login
AUTH_BOOTSTRAP_ADMINS=you@yourcompany.com

# Set true to skip login in local dev only (never use in production)
VITE_BYPASS_AUTH=true

# Supabase (production — persistent user access; see docs/SUPABASE_GO_LIVE.md)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# VITE_SUPABASE_ANON_KEY=   # optional, future client reads

# Production: npm run build && npm start (serves dist + API on PORT)
# NODE_ENV=production
