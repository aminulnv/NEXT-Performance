# Revolut People API (server only — never prefix with VITE_)
REVOLUT_EMAIL=your-email@company.com
REVOLUT_TOKEN=your-api-token

# Local API server
API_PORT=3001
PORT=3001
# Cache Revolut responses in memory (milliseconds)
API_CACHE_MS=3600000
STALE_REFRESH_MS=21600000
REVOLUT_PAGE_DELAY_MS=350
INCLUDE_SCORECARDS=true
INCLUDE_ALL_SCORECARDS=true

# Public site URL (optional in production — Vercel uses request Host / VERCEL_URL if unset)
# Local dev only — do not set localhost APP_URL on Vercel (OAuth will redirect to localhost).
APP_URL=http://localhost:5173
# Production Vercel: https://your-project.vercel.app
# Extra browser origins for production CORS (comma-separated, optional)
# CORS_ORIGINS=https://next-performance-beta.vercel.app

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-me-to-a-long-random-string
# Session cookie lifetime in ms (default 86400000 = 24 hours)
# SESSION_MAX_AGE_MS=86400000
ALLOWED_EMAIL_DOMAIN=yourcompany.com
# Comma-separated emails that become admin on first Google login
AUTH_BOOTSTRAP_ADMINS=you@yourcompany.com

# Set true to skip login in local dev only (ignored in production builds and on the API server)
VITE_BYPASS_AUTH=true

# Supabase (production — persistent user access; see docs/SUPABASE_GO_LIVE.md)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# VITE_SUPABASE_ANON_KEY=   # optional, future client reads

# Encrypted Revolut cache in Supabase (server only — generate once, never commit)
# openssl rand -base64 32
PERFORMANCE_DATA_ENCRYPTION_KEY=

# Vercel cron auth (production — Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Rate limiting (production on by default; set RATE_LIMIT_ENABLED=true to test locally)
# RATE_LIMIT_DISABLED=true

# Local full-stack: npm run build:node && npm start
# Production: deploy to Vercel — see docs/DEPLOY_VERCEL.md
# NODE_ENV=production
