{
  "name": "performance-dashboard",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.mjs",
    "build": "npm run build:render",
    "build:render": "NPM_CONFIG_PRODUCTION=false npm install && npm run build:app",
    "build:app": "tsc -b && vite build",
    "build:local": "npm run build:app",
    "build:vercel": "node scripts/prepare-vercel.mjs && npm run build:app",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "start:api": "node server/index.mjs",
    "cache:warm": "node server/warm-cache.mjs",
    "test": "vitest run && node --test server/parseGoalsCsv.test.mjs server/parseAccessCsv.test.mjs server/permissionsValidation.test.mjs server/employeeLookup.test.mjs server/reportingTree.test.mjs",
    "access:import": "node server/importAccessCsv.mjs",
    "access:migrate-supabase": "node server/migrateAccessToSupabase.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "google-auth-library": "^9.15.1",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vitest": "^3.2.4"
  }
}
